source "https://rubygems.org"

# Local-only Gemfile. GitHub Pages builds the site server-side using its own
# pinned gem set, so this file does not affect production. Keep it minimal so
# Ruby upgrades don't break local `jekyll serve`.

gem "jekyll", "~> 4.3"

group :jekyll_plugins do
  gem "jekyll-feed",         "~> 0.17"
  gem "jekyll-seo-tag",      "~> 2.8"
  gem "jekyll-remote-theme", "~> 0.4"
end

# Ruby 3.4+ no longer ships these as default gems; Jekyll still needs them.
gem "csv"
gem "base64"
gem "logger"
